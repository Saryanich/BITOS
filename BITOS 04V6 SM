class BITOS:
    def __init__(self):
        self.version = "04V6 SM"
        self.build = "2026.02"
        self.running = True
        self.start_time = time.time()
        self.current_user = "User1"
        
        # ========== БАЗОВАЯ СТРУКТУРА ==========
        # Пути создаются ТАМ, ГДЕ НАХОДИТСЯ КОД
        self.base_path = os.path.dirname(os.path.abspath(__file__))
        
        # Системные пути
        self.system_paths = {
            "system": os.path.join(self.base_path, "System"),
            "users": os.path.join(self.base_path, "User")
        }
        
        # Пользовательские пути
        self.user_paths = {
            "home": os.path.join(self.base_path, "User", self.current_user),
            "file": os.path.join(self.base_path, "User", self.current_user, "File"),
            "secure": os.path.join(self.base_path, "User", self.current_user, "Secure")
        }
        
        # Основные пути
        self.documents_path = self.user_paths["file"]
        self.secure_path = self.user_paths["secure"]
        self.temp_path = os.path.join(self.base_path, "System", "Temp")
        
        # Запрещенные пути (диск C и выход за пределы BITOS)
        self.forbidden_paths = [
            "C:\\",
            "C:/",
            "/Windows",
            "/System32",
            "C:\\Windows",
            "C:\\System32"
        ]
        
        self.initialize_system()

    # ========== ПРОВЕРКА ПУТИ ==========
    
    def is_path_safe(self, path):
        """Проверяет, что путь не выходит за пределы папки BITOS и не ведет на диск C"""
        try:
            # Нормализуем путь
            real_path = os.path.realpath(os.path.abspath(path))
            base_real = os.path.realpath(os.path.abspath(self.base_path))
            
            # Проверяем, что путь внутри BITOS
            if not real_path.startswith(base_real):
                return False
            
            # Проверяем, что не пытаемся попасть на диск C
            if real_path.upper().startswith("C:"):
                # Разрешаем только если это внутри нашей папки
                if not real_path.upper().startswith(base_real.upper()):
                    return False
            
            return True
        except:
            return False

    # ========== СОЗДАНИЕ ДИРЕКТОРИЙ ==========
    
    def ensure_directories(self):
        """Создает все необходимые директории"""
        for path in self.system_paths.values():
            os.makedirs(path, exist_ok=True)
        for path in self.user_paths.values():
            os.makedirs(path, exist_ok=True)
        os.makedirs(self.temp_path, exist_ok=True)

    # ========== ЗАГРУЗКА ==========
    
    def boot_animation(self, duration=3):
        """Анимация загрузки с точками"""
        base_text = f"BITOS v{self.version} is booting"
        sys.stdout.write(base_text)
        sys.stdout.flush()
        dots = ["", ".", "..", "..."]
        end_time = time.time() + duration
        i = 0
        last_dots = ""
        
        while time.time() < end_time:
            d = dots[i % len(dots)]
            # Удаляем предыдущие точки
            for _ in range(len(last_dots)):
                sys.stdout.write('\b \b')
            sys.stdout.write(d)
            sys.stdout.flush()
            last_dots = d
            time.sleep(0.5)
            i += 1
        
        # Очищаем точки и показываем галочку
        for _ in range(len(last_dots)):
            sys.stdout.write('\b \b')
        sys.stdout.write("... ✓\n")
        sys.stdout.flush()

    def background_check(self):
        """Проверка системы при загрузке"""
        results = []
        main_dirs = [
            self.system_paths["system"],
            self.documents_path,
            self.secure_path,
            self.temp_path
        ]
        
        for path in main_dirs:
            exists = os.path.exists(path)
            status = "OK" if exists else "Created"
            results.append((path, exists, status))
            if not exists:
                os.makedirs(path, exist_ok=True)
        
        return results

    def show_diagnostics(self):
        """Показывает результаты диагностики"""
        self.check_results = self.background_check()
        all_ok = all(exists for _, exists, _ in self.check_results)
        
        if all_ok:
            print("✓ All systems OK. Command line started.")
        else:
            print("⚠ Some systems recovered. Command line started.")

    def initialize_system(self):
        """Инициализация системы"""
        print(f"\n🚀 BITOS v{self.version} инициализация...")
        self.ensure_directories()
        print("✓ Система готова")

    # ========== ФАЙЛОВЫЕ ОПЕРАЦИИ ==========
    
    def list_directory(self, path=None, detailed=False):
        """Список файлов и папок"""
        if path is None:
            path = self.documents_path
        elif not os.path.isabs(path):
            # Относительный путь
            path = os.path.join(self.documents_path, path)
        
        if not self.is_path_safe(path):
            print("❌ Доступ запрещен: выход за пределы BITOS")
            return
        
        if not os.path.exists(path):
            print(f"❌ Путь не существует: {path}")
            return
        
        items = os.listdir(path)
        if not items:
            print("(пусто)")
            return
        
        print(f"\n📁 {path}")
        print("=" * 50)
        
        for item in sorted(items):
            full_path = os.path.join(path, item)
            if os.path.isdir(full_path):
                print(f"  📁 {item}/")
            else:
                size = os.path.getsize(full_path)
                mtime = datetime.fromtimestamp(os.path.getmtime(full_path))
                if detailed:
                    print(f"  📄 {item:<30} {size:>8} байт  {mtime.strftime('%Y-%m-%d %H:%M')}")
                else:
                    print(f"  📄 {item} ({size} байт)")

    def change_directory(self, path):
        """Смена директории"""
        if path == "..":
            # Переход на уровень выше
            new_path = os.path.dirname(self.documents_path)
            if not self.is_path_safe(new_path):
                print("❌ Доступ запрещен: нельзя выйти за пределы BITOS")
                return
            self.documents_path = new_path
            print(f"📁 {self.documents_path}")
            return
        
        # Абсолютный или относительный путь
        if os.path.isabs(path):
            new_path = path
        else:
            new_path = os.path.join(self.documents_path, path)
        
        if not self.is_path_safe(new_path):
            print("❌ Доступ запрещен: выход за пределы BITOS")
            return
        
        if not os.path.exists(new_path):
            print(f"❌ Папка не существует: {path}")
            return
        
        if not os.path.isdir(new_path):
            print(f"❌ Это не папка: {path}")
            return
        
        self.documents_path = new_path
        print(f"📁 {self.documents_path}")

    def show_current_path(self):
        """Показать текущий путь"""
        print(f"📁 {self.documents_path}")

    def create_directory(self, dirname):
        """Создание папки"""
        path = os.path.join(self.documents_path, dirname)
        
        if not self.is_path_safe(path):
            print("❌ Доступ запрещен")
            return
        
        if os.path.exists(path):
            print(f"❌ Папка уже существует: {dirname}")
            return
        
        os.makedirs(path, exist_ok=True)
        print(f"✅ Создана папка: {dirname}")

    def create_document(self, filename):
        """Создание текстового документа"""
        if not filename.endswith('.txt'):
            filename += '.txt'
        
        path = os.path.join(self.documents_path, filename)
        
        if not self.is_path_safe(path):
            print("❌ Доступ запрещен")
            return
        
        if os.path.exists(path):
            if input("Перезаписать? (y/n): ").lower() != 'y':
                return
        
        print("Введите текст (Ctrl+Z для сохранения):")
        lines = []
        try:
            while True:
                lines.append(input())
        except EOFError:
            pass
        
        with open(path, 'w', encoding='utf-8') as f:
            f.write('\n'.join(lines))
        
        print(f"✅ Создан: {filename}")

    def read_document(self, filename):
        """Чтение документа"""
        if not filename.endswith('.txt'):
            filename += '.txt'
        
        path = os.path.join(self.documents_path, filename)
        
        if not os.path.exists(path):
            print(f"❌ Файл не найден: {filename}")
            return
        
        if not self.is_path_safe(path):
            print("❌ Доступ запрещен")
            return
        
        with open(path, 'r', encoding='utf-8') as f:
            content = f.read()
        
        print(f"\n{'='*50}")
        print(f"📄 {filename}")
        print(f"{'='*50}")
        print(content)
        print(f"{'='*50}")

    def edit_document(self, filename):
        """Редактирование документа"""
        if not filename.endswith('.txt'):
            filename += '.txt'
        
        path = os.path.join(self.documents_path, filename)
        
        if not os.path.exists(path):
            print(f"❌ Файл не найден: {filename}")
            return
        
        if not self.is_path_safe(path):
            print("❌ Доступ запрещен")
            return
        
        # Показываем текущее содержимое
        with open(path, 'r', encoding='utf-8') as f:
