    def disk_usage(self, path=None):
        """Информация о диске"""
        if path is None:
            path = self.base_path
        
        if not os.path.exists(path):
            print(f"❌ Путь не существует: {path}")
            return
        
        try:
            usage = shutil.disk_usage(path)
            print(f"\n💿 {path}")
            print(f"Всего: {usage.total/1024**3:.1f} GB")
            print(f"Свободно: {usage.free/1024**3:.1f} GB")
            print(f"Использовано: {usage.used/1024**3:.1f} GB")
            print(f"Использование: {(usage.used/usage.total)*100:.1f}%")
        except Exception as e:
            print(f"❌ Ошибка: {e}")

    def calculator(self, expr=None):
        """Калькулятор"""
        if expr is None:
            expr = input("Выражение: ")
        
        if not expr:
            return
        
        try:
            # Безопасное вычисление
            safe_dict = {
                'abs': abs, 'round': round, 'int': int, 'float': float,
                'pi': math.pi, 'e': math.e, 'sqrt': math.sqrt,
                'sin': math.sin, 'cos': math.cos, 'tan': math.tan,
                'log': math.log, 'log10': math.log10,
                'pow': math.pow, 'exp': math.exp
            }
            result = eval(expr, {"__builtins__": {}}, safe_dict)
            print(f"= {result}")
        except Exception as e:
            print(f"❌ Ошибка: {e}")

    def temp_cleanup(self):
        """Очистка временных файлов"""
        if not os.path.exists(self.temp_path):
            print("Нет временных файлов")
            return
        
        total = 0
        count = 0
        
        for item in os.listdir(self.temp_path):
            item_path = os.path.join(self.temp_path, item)
            try:
                if os.path.isfile(item_path):
                    total += os.path.getsize(item_path)
                    os.remove(item_path)
                    count += 1
                elif os.path.isdir(item_path):
                    shutil.rmtree(item_path)
                    count += 1
            except Exception as e:
                print(f"⚠ Ошибка при удалении {item}: {e}")
        
        print(f"✅ Удалено {count} объектов, освобождено {total} байт")

