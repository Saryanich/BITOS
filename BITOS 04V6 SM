        print("\nВведите новый текст (Ctrl+Z для сохранения):")
        lines = []
        try:
            while True:
                lines.append(input())
        except EOFError:
            pass
        
        with open(path, 'w', encoding='utf-8') as f:
            f.write('\n'.join(lines))
        
        print(f"✅ Обновлен: {filename}")

    def delete_file(self, filename):
        """Удаление файла или папки"""
        path = os.path.join(self.documents_path, filename)
        
        if not os.path.exists(path):
            print(f"❌ Не найден: {filename}")
            return
        
        if not self.is_path_safe(path):
            print("❌ Доступ запрещен")
            return
        
        if input(f"Удалить {filename}? (y/n): ").lower() == 'y':
            if os.path.isdir(path):
                shutil.rmtree(path)
                print(f"✅ Папка удалена: {filename}")
            else:
                os.remove(path)
                print(f"✅ Файл удален: {filename}")

    def copy_file(self, source, destination):
        """Копирование файла"""
        src_path = os.path.join(self.documents_path, source)
        
        if not os.path.exists(src_path):
            print(f"❌ Источник не найден: {source}")
            return
        
        if not self.is_path_safe(src_path):
            print("❌ Доступ запрещен")
            return
        
        # Определяем путь назначения
        if os.path.isabs(destination):
            dst_path = destination
        else:
            dst_path = os.path.join(self.documents_path, destination)
        
        if not self.is_path_safe(dst_path):
            print("❌ Доступ запрещен: выход за пределы BITOS")
            return
        
        try:
            if os.path.isdir(src_path):
                shutil.copytree(src_path, dst_path)
            else:
                shutil.copy2(src_path, dst_path)
            print(f"✅ Скопировано: {source} -> {destination}")
        except Exception as e:
            print(f"❌ Ошибка копирования: {e}")

    def move_file(self, source, destination):
        """Перемещение файла"""
        src_path = os.path.join(self.documents_path, source)
        
        if not os.path.exists(src_path):
            print(f"❌ Источник не найден: {source}")
            return
        
        if not self.is_path_safe(src_path):
            print("❌ Доступ запрещен")
            return
        
        if os.path.isabs(destination):
            dst_path = destination
        else:
            dst_path = os.path.join(self.documents_path, destination)
        
        if not self.is_path_safe(dst_path):
            print("❌ Доступ запрещен: выход за пределы BITOS")
            return
        
        try:
            shutil.move(src_path, dst_path)
            print(f"✅ Перемещено: {source} -> {destination}")
        except Exception as e:
            print(f"❌ Ошибка перемещения: {e}")

    def tree_view(self, path=None, prefix="", is_last=True, show_files=True):
        """Текстовый проводник в виде дерева"""
        if path is None:
            path = self.base_path
        
        if not self.is_path_safe(path):
            return
        
        if not os.path.exists(path):
            print(f"❌ Путь не существует: {path}")
            return
        
        # Показываем корневую папку
        if prefix == "":
            print(f"\n🌳 ДЕРЕВО BITOS")
            print("=" * 50)
            print(f"📁 {os.path.basename(path)}/")
        
        try:
            items = sorted(os.listdir(path))
        except PermissionError:
            print(f"{prefix}🚫 Доступ запрещен")
            return
        
        # Фильтруем: сначала папки, потом файлы
        dirs = []
        files = []
        
        for item in items:
            full_path = os.path.join(path, item)
            if os.path.isdir(full_path):
                dirs.append(item)
            elif show_files:
                files.append(item)
        
        # Обрабатываем папки
        for i, item in enumerate(dirs):
            is_last_item = (i == len(dirs) - 1) and (len(files) == 0)
            connector = "└── " if is_last_item else "├── "
            print(f"{prefix}{connector}📁 {item}/")
            
            # Рекурсивно показываем содержимое
            extension = "    " if is_last_item else "│   "
            full_path = os.path.join(path, item)
            self.tree_view(full_path, prefix + extension, is_last_item, show_files)
        
        # Обрабатываем файлы
        if show_files:
            for i, item in enumerate(files):
                is_last_file = (i == len(files) - 1)
                connector = "└── " if is_last_file else "├── "
                full_path = os.path.join(path, item)
                size = os.path.getsize(full_path)
                print(f"{prefix}{connector}📄 {item} ({size} байт)")

