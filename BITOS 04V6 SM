    def reboot(self):
        """Перезагрузка системы"""
        print("🔄 Перезагрузка...")
        time.sleep(1)
        self.running = False
        # Перезапускаем скрипт
        python = sys.executable
        script = os.path.abspath(__file__)
        subprocess.Popen([python, script])
        sys.exit(0)

    # ========== ОСНОВНОЙ ЦИКЛ ==========
    
    def shell(self):
        """Командная оболочка"""
        while self.running:
            try:
                cmd = input("\nbitos> ").strip()
                
                if not cmd:
                    continue
                
                parts = cmd.split()
                main = parts[0].lower()
                
                # ===== ФАЙЛОВЫЕ КОМАНДЫ =====
                
                if main in ["ls", "dir"]:
                    detailed = len(parts) > 1 and parts[1] == "detail"
                    self.list_directory(None, detailed)
                
                elif main in ["tree", "древо"]:
                    show_files = True
                    if len(parts) > 1 and parts[1] == "folders":
                        show_files = False
                    self.tree_view(show_files=show_files)
                
                elif main in ["cd", "перейти"]:
                    if len(parts) > 1:
                        self.change_directory(parts[1])
                    else:
                        self.documents_path = self.user_paths["file"]
                        print(f"📁 {self.documents_path}")
                
                elif main in ["pwd", "где"]:
                    self.show_current_path()
                
                elif main in ["mkdir", "создать_папку"]:
                    if len(parts) > 1:
                        self.create_directory(parts[1])
                    else:
                        print("❌ Укажите имя папки")
                
                elif main in ["rm", "удалить"]:
                    if len(parts) > 1:
                        self.delete_file(parts[1])
                    else:
                        print("❌ Укажите имя файла/папки")
                
                elif main in ["create", "создать"]:
                    if len(parts) > 1:
                        self.create_document(parts[1])
                    else:
                        print("❌ Укажите имя файла")
                
                elif main in ["read", "прочитать"]:
                    if len(parts) > 1:
                        self.read_document(parts[1])
                    else:
                        print("❌ Укажите имя файла")
                
                elif main in ["edit", "редактировать"]:
                    if len(parts) > 1:
                        self.edit_document(parts[1])
                    else:
                        print("❌ Укажите имя файла")
                
                elif main in ["copy", "копировать"]:
                    if len(parts) >= 3:
                        self.copy_file(parts[1], parts[2])
                    else:
                        print("❌ Укажите источник и назначение")
                
                elif main in ["move", "переместить"]:
                    if len(parts) >= 3:
                        self.move_file(parts[1], parts[2])
                    else:
                        print("❌ Укажите источник и назначение")
                
                # ===== СИСТЕМНЫЕ КОМАНДЫ =====
                
                elif main in ["sysinfo", "система"]:
                    self.system_info()
                
                elif main in ["time", "дата"]:
                    self.show_time_date()
                
                elif main in ["disk", "диск"]:
                    path = parts[1] if len(parts) > 1 else None
                    self.disk_usage(path)
                
                elif main in ["calc", "калькулятор"]:
                    expr = ' '.join(parts[1:]) if len(parts) > 1 else None
                    self.calculator(expr)
                
                elif main in ["cleanup", "очистка"]:
                    self.temp_cleanup()
                
                elif main in ["clear", "очистить"]:
                    self.clear_screen()
                
                elif main in ["reboot", "перезагрузка"]:
                    self.reboot()
                
                elif main in ["exit", "выход"]:
                    print("👋 До свидания!")
                    self.running = False
                
                elif main in ["help", "помощь"]:
                    self.show_help()
                
                else:
                    print(f"❌ Неизвестная команда: {main}")
                    print("Введите 'help' для списка команд")
            
            except KeyboardInterrupt:
                print("\n⚠ Для выхода введите 'exit'")
            except EOFError:
                break
            except Exception as e:
                print(f"❌ Ошибка: {e}")

    def run(self):
        """Запуск системы"""
        # Установка полноэкранного режима
        if os.name == 'nt':
            os.system('mode con: cols=120 lines=40')
        
        self.boot_animation(3)
        self.show_diagnostics()
        print(f"\n📁 Система установлена в: {self.base_path}")
        print("Введите 'help' для списка команд\n")
        self.shell()


if __name__ == "__main__":
    bitos = BITOS()
    bitos.run()
